{
    "rules": {
        "type": "template_list",
        "description": "配置关键词拦截规则。匹配到的消息将不会传给 LLM",
        "templates": {
            "keyword_rule": {
                "name": "关键词拦截规则",
                "hint": "添加一个新的关键词拦截规则",
                "items": {
                    "name": {
                        "description": "匹配内容",
                        "type": "string",
                        "default": "关键词拦截规则",
                        "hint": "关键词拦截规则的匹配内容"
                    },
                    "match_type": {
                        "description": "匹配模式",
                        "type": "string",
                        "options": ["keyword", "exact", "regex"],
                        "default": "keyword",
                        "hint": "keyword: 包含即可；exact: 必须完全一致；regex: 正则表达式"
                    },
                    "enabled": {
                        "description": "是否启用此规则",
                        "type": "bool",
                        "default": true
                    },
                    "intercept_quote_only": {
                        "description": "仅拦截引用回复",
                        "type": "bool",
                        "default": false,
                        "hint": "开启后，只有当消息是引用回复且包含关键词时才拦截"
                    },
                    "apply_to_all": {
                        "description": "应用到所有聊天",
                        "type": "bool",
                        "default": true
                    },
                    "target_chats": {
                        "description": "指定聊天 ID 列表",
                        "type": "list",
                        "item_type": "string",
                        "default": [],
                        "hint": "当'应用到所有聊天'关闭时，在此处填写群号或私聊 SID (Session ID)"
                    }
                }
            }
        },
        "default": []
    }
}
